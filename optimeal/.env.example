# Firebase client config. Firebase web config is not a server secret, but use
# your own project values when running or deploying a fork.
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
REACT_APP_FIREBASE_MEASUREMENT_ID=

# Public Vercel serverless endpoint for authenticated AI meal generation.
# This URL is safe in React because it is only the public API endpoint.
REACT_APP_MEAL_PLAN_ENDPOINT=https://your-vercel-project.vercel.app/api/generateMealPlan

# OpenRouter secrets are stored in Vercel environment variables, not React.
# Required Vercel env vars:
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=
# ALLOWED_ORIGINS=
# FIREBASE_SERVICE_ACCOUNT_JSON=
